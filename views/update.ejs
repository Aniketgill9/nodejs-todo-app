<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>update task</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<%- include("navbar") %>

<div class="container">
    <h1>Update Task</h1>

    <!-- ✅ IMPORTANT: send id in URL -->
    <form class="add-from" action="/update/<%= data._id %>" method="post">

        <!-- ✅ Pre-fill title -->
        <input 
            class="input" 
            type="text" 
            name="title" 
            value="<%= data.title %>"
        >

        <br><br>

        <!-- ✅ Pre-fill description -->
        <textarea class="input" name="description"><%= data.description || data.discription %></textarea>

        <br><br>

        <button class="btn">Update Task</button>
    </form>
</div>

</body>
</html>